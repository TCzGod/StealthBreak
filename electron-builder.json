{
  "appId": "com.stealthbreak.app",
  "productName": "StealthBreak",
  "copyright": "Copyright © 2026 StealthBreak",
  "directories": {
    "output": "dist-electron",
    "buildResources": "assets"
  },
  "files": [
    "dist/**/*",
    "src/main/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64", "ia32"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "assets/icon.ico",
    "publisherName": "StealthBreak"
  },
  "mac": {
    "target": [
      "dmg",
      "zip"
    ],
    "icon": "assets/icon.icns",
    "category": "utilities"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "perMachine": true,
    "deleteAppDataOnUninstall": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}